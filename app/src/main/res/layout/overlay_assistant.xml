<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/overlayRoot"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="@android:color/transparent">

    <TextView
        android:id="@+id/txtBubble"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:gravity="center"
        android:text="AI"
        android:textSize="16sp"
        android:textStyle="bold"
        android:background="@android:drawable/btn_default" />

    <LinearLayout
        android:id="@+id/panelContainer"
        android:layout_width="260dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp"
        android:visibility="gone"
        android:background="@android:drawable/dialog_holo_light_frame">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/txtPanelTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Message Suggestions"
                android:textSize="16sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnMinimise"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="–" />
        </LinearLayout>

        <TextView
            android:id="@+id/txtPanelSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="6dp"
            android:paddingBottom="10dp"
            android:text="Suggestions will appear here."
            android:textSize="12sp" />

        <Button
            android:id="@+id/btnSuggestion1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Suggestion 1" />

        <Button
            android:id="@+id/btnSuggestion2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Suggestion 2" />

        <Button
            android:id="@+id/btnSuggestion3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Suggestion 3" />
    </LinearLayout>

</FrameLayout>